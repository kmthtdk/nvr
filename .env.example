# ──────────────────────────────────────────────
# NVR Dashboard - Environment Configuration
# ──────────────────────────────────────────────

# Backend Server
PORT=3001
NODE_ENV=development

# JWT Authentication
JWT_SECRET=change-this-to-a-strong-random-secret-minimum-32-chars
JWT_EXPIRY=24h

# Default Admin Credentials (change on first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# go2rtc Media Server
GO2RTC_HOST=localhost
GO2RTC_PORT=1984
GO2RTC_API_URL=http://localhost:1984
# Set these ONLY if go2rtc Basic auth is enabled so backend calls authenticate.
# Leave blank for the default (loopback-bound go2rtc fronted by a reverse proxy).
GO2RTC_USERNAME=
GO2RTC_PASSWORD=

# SQLite Database
DATABASE_PATH=./data/nvr-dashboard.db

# NVR Connection Defaults
NVR_DEFAULT_RTSP_PORT=554
NVR_DEFAULT_HTTP_PORT=80
NVR_MAX_CONCURRENT_STREAMS=10

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# ──────────────────────────────────────────────
# Example NVR Device Configuration
# Add these via the Device Manager UI, not here.
# Format reference:
#   Name: "Building A NVR"
#   IP: 192.168.1.100
#   Port: 80
#   RTSP Port: 554
#   Username: admin
#   Password: ********
#   Channels: 16 (XRN-1620SB1 supports up to 16)
# ──────────────────────────────────────────────
